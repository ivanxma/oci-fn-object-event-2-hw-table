# Copy to env.sh, fill locally, and chmod 600 env.sh. Never commit env.sh.
export COMPARTMENT_ID=''
export SUBNET_ID=''
export APP_NAME='object-event-2-table'
export FUNCTION_NAME='object-event-2-table'
export REGION=''
export REGION_KEY=''
export REPOSITORY_PREFIX=''
export OCIR_USERNAME=''
export OCIR_AUTH_TOKEN=''
export DB_HOST=''
export DB_PORT='3306'
export DB_USER=''
export DB_PASSWORD=''
# Control schema holding mappings, batches, event logs, and object_event.
# DB_NAME is retained for compatibility with earlier deployment settings.
export DB_NAME='fndb3'
export CONTROL_DATABASE='fndb3'
# Optional Function configuration values.
export DB_SSL_DISABLED='false'
export OBJECT_STORAGE_NAMESPACE=''
export BATCH_ROWS='1000'
export WRITER_WORKERS='4'
# Restrict the Events rule to one bucket when required; blank means all buckets.
export OBJECT_STORAGE_BUCKET_NAME=''
# Optional OCI Events object-name filter. Object Storage folders are prefixes
# in the object name. Example: `myfolder/*.csv`; blank means every object.
export OBJECT_STORAGE_OBJECT_NAME_PATTERN=''
# Enable OCI Functions invocation logging during deployment. Supply a log group
# OCID; the deployment creates or reuses the application invoke log.
export ENABLE_FUNCTION_LOG='true'
export FUNCTION_LOG_GROUP_ID=''
export FUNCTION_LOG_NAME=''
export RULE_NAME='object-event-2-table-events'

# Flask UI HTTPS deployment (used by deploy/deploy_ui.sh).
# Set this to a long random value and keep env.sh mode 0600.
export FLASK_SECRET_KEY=''
export UI_SERVICE_NAME='object-storage-heatwave-ui'
export UI_CONTAINER_NAME='object-storage-heatwave-ui'
# Nginx serves public HTTPS on 443 and proxies to this localhost-only port.
export UI_BIND_PORT='8080'
export UI_SERVER_NAME='_'
# Set paths to a CA-signed certificate and private key, or explicitly allow a
# temporary self-signed certificate for testing.
export TLS_CERT_FILE=''
export TLS_KEY_FILE=''
export GENERATE_SELF_SIGNED_CERT='false'
